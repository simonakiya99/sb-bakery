---
import Layout from '../layouts/Layout.astro'
import '../index.css'
---
<Layout lang="nl" title="404 — SB Bakery" description="Pagina niet gevonden">
  <div class="not-found">
    <div class="not-found-inner">
      <div class="not-found-icon">🎂</div>
      <h1 class="not-found-title">404</h1>
      <p class="not-found-sub">Pagina niet gevonden</p>
      <p class="not-found-msg">De pagina die u zoekt bestaat niet of is verplaatst.</p>
      <a href="/" class="btn-primary not-found-btn">← Terug naar home</a>
    </div>
  </div>
</Layout>
