---
import Layout from '../../layouts/Layout.astro'
import Navbar from '../../components/Navbar.astro'
import Hero from '../../components/Hero.astro'
import About from '../../components/About.astro'
import WorkGallery from '../../components/WorkGallery.astro'
import GalleryIsland from '../../components/Gallery.jsx'
import Testimonials from '../../components/Testimonials.jsx'
import Courses from '../../components/Courses.astro'
import FAQ from '../../components/FAQ.astro'
import OrderIsland from '../../components/Order.jsx'
import Footer from '../../components/Footer.astro'
import '../../index.css'

const lang = 'ti'
---
<Layout
  lang={lang}
  title="SB — ናይ ሰላም ኬካታት"
  description="ብኢድ ዝተሰርሑ ሉኹስ ኬካታት ንፍሉያት ናይ ህይወትኩም ግዜያት። ናይ መርዓ ኬካታት፡ ናይ ልደት ኬካታትን ካልኦትን።"
>
  <Navbar lang={lang} />
  <Hero lang={lang} />
  <About lang={lang} />
  <WorkGallery lang={lang} />
  <GalleryIsland lang={lang} client:load />
  <Testimonials lang={lang} client:load />
  <Courses lang={lang} />
  <FAQ lang={lang} />
  <OrderIsland lang={lang} client:load />
  <Footer lang={lang} />
</Layout>
