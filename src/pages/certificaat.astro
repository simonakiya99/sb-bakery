---
// Standalone certificate page — no main Layout
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Certificate — SB Bakery</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,600&family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Montserrat', sans-serif;
      background: #ebe8e1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 2.5rem 1rem 4rem;
    }

    /* ── Controls ── */
    .controls {
      background: white;
      border-radius: 12px;
      padding: 1.2rem 1.6rem;
      margin-bottom: 2rem;
      display: flex;
      gap: 1rem;
      align-items: flex-end;
      flex-wrap: wrap;
      box-shadow: 0 2px 16px rgba(0,0,0,0.08);
      width: 100%;
      max-width: 860px;
    }

    .control-group {
      display: flex;
      flex-direction: column;
      gap: 0.32rem;
      flex: 1;
      min-width: 160px;
    }

    .control-group label {
      font-size: 0.68rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #999;
    }

    .control-group input,
    .control-group select {
      padding: 0.52rem 0.72rem;
      border: 1.5px solid #e0ddd5;
      border-radius: 7px;
      font-family: 'Montserrat', sans-serif;
      font-size: 0.86rem;
      color: #333;
      outline: none;
      transition: border-color 0.2s;
      background: white;
    }

    .control-group input:focus,
    .control-group select:focus {
      border-color: #C9A84C;
    }

    .btn-download {
      padding: 0.56rem 1.4rem;
      background: #C9A84C;
      color: white;
      border: none;
      border-radius: 7px;
      font-family: 'Montserrat', sans-serif;
      font-size: 0.86rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.2s, transform 0.1s;
      letter-spacing: 0.04em;
    }

    .btn-download:hover  { background: #b8933b; }
    .btn-download:active { transform: scale(0.97); }
    .btn-download:disabled { opacity: 0.6; cursor: default; transform: none; }

    /* ── Certificate shell ── */
    #certificaat {
      width: 297mm;
      height: 210mm;
      background: #fffdf8;
      position: relative;
      overflow: hidden;
      box-shadow: 0 8px 48px rgba(0,0,0,0.18);
    }

    /* Subtle texture overlay */
    #certificaat::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(ellipse at 15% 20%, rgba(201,168,76,0.04) 0%, transparent 60%),
        radial-gradient(ellipse at 85% 80%, rgba(201,168,76,0.04) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    /* Borders */
    .cert-border-outer {
      position: absolute;
      inset: 8mm;
      border: 2px solid #C9A84C;
      pointer-events: none;
      z-index: 1;
    }

    .cert-border-inner {
      position: absolute;
      inset: 11.5mm;
      border: 0.5px solid rgba(201,168,76,0.45);
      pointer-events: none;
      z-index: 1;
    }

    /* Corner ornaments */
    .cert-corner {
      position: absolute;
      color: #C9A84C;
      font-size: 16px;
      z-index: 2;
      line-height: 1;
    }
    .cert-corner.tl { top: 13mm;  left: 13mm;  }
    .cert-corner.tr { top: 13mm;  right: 13mm; }
    .cert-corner.bl { bottom: 13mm; left: 13mm; }
    .cert-corner.br { bottom: 13mm; right: 13mm; }

    /* Content */
    .cert-content {
      position: absolute;
      inset: 0;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 16mm 24mm;
      gap: 0;
    }

    .cert-logo {
      width: 62px;
      height: auto;
      margin-bottom: 5px;
      display: block;
    }

    .cert-brand {
      font-family: 'Montserrat', sans-serif;
      font-size: 8.5px;
      font-weight: 600;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: #C9A84C;
      margin-bottom: 11px;
    }

    .cert-top-rule {
      width: 180px;
      height: 1px;
      background: linear-gradient(90deg, transparent, #C9A84C 30%, #C9A84C 70%, transparent);
      margin-bottom: 11px;
    }

    .cert-title {
      font-family: 'Cormorant Garamond', 'Playfair Display', serif;
      font-size: 36px;
      font-weight: 600;
      color: #1a1a1a;
      letter-spacing: 0.02em;
      line-height: 1.1;
      margin-bottom: 10px;
    }

    .cert-name-label {
      font-size: 8px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #bbb;
      margin-bottom: 5px;
    }

    .cert-name {
      font-family: 'Cormorant Garamond', 'Playfair Display', serif;
      font-size: 34px;
      font-style: italic;
      font-weight: 400;
      color: #1a1a1a;
      min-height: 42px;
      line-height: 1.15;
      margin-bottom: 11px;
    }

    .cert-mid-rule {
      width: 52px;
      height: 1.5px;
      background: #C9A84C;
      margin-bottom: 11px;
    }

    .cert-body-text {
      font-family: 'Cormorant Garamond', 'Playfair Display', serif;
      font-size: 13.5px;
      font-style: italic;
      color: #444;
      line-height: 1.6;
      max-width: 340px;
      margin-bottom: 6px;
    }

    .cert-wish-text {
      font-family: 'Cormorant Garamond', 'Playfair Display', serif;
      font-size: 13px;
      color: #777;
      line-height: 1.5;
      margin-bottom: 14px;
    }

    .cert-footer {
      display: flex;
      gap: 60px;
      align-items: flex-end;
    }

    .cert-sig-block {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }

    .cert-sig-line {
      width: 88px;
      height: 1px;
      background: #555;
    }

    .cert-sig-label {
      font-family: 'Montserrat', sans-serif;
      font-size: 7.5px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #888;
    }
  </style>
</head>
<body>

  <div class="controls">
    <div class="control-group">
      <label>Recipient name</label>
      <input type="text" id="naam-input" placeholder="e.g. Fatima Hassan" />
    </div>
    <div class="control-group" style="max-width:180px">
      <label>Date</label>
      <input type="date" id="datum-input" />
    </div>
    <button class="btn-download" id="download-btn">⬇ Download PDF</button>
  </div>

  <div id="certificaat">
    <div class="cert-border-outer"></div>
    <div class="cert-border-inner"></div>

    <div class="cert-corner tl">✦</div>
    <div class="cert-corner tr">✦</div>
    <div class="cert-corner bl">✦</div>
    <div class="cert-corner br">✦</div>

    <div class="cert-content">
      <img src="/logo.png" alt="SB Bakery" class="cert-logo" onerror="this.style.display='none'" />
      <div class="cert-brand">SB &nbsp;Bakery</div>

      <div class="cert-top-rule"></div>

      <h1 class="cert-title">Certificate of Appreciation</h1>

      <div class="cert-name-label">presented to</div>
      <div class="cert-name" id="cert-name-display">—</div>

      <div class="cert-mid-rule"></div>

      <p class="cert-body-text">
        In recognition of dedication, creativity, and passion<br />
        shown in cake making and decoration.
      </p>
      <p class="cert-wish-text">Wishing continued growth, success, and joy ahead.</p>

      <div class="cert-footer">
        <div class="cert-sig-block">
          <div class="cert-sig-line"></div>
          <div class="cert-sig-label" id="cert-date-display">Date</div>
        </div>
        <div class="cert-sig-block">
          <div class="cert-sig-line"></div>
          <div class="cert-sig-label">Signature &nbsp;·&nbsp; SB Bakery</div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  <script is:inline>
    const naamInput   = document.getElementById('naam-input')
    const datumInput  = document.getElementById('datum-input')
    const nameDisplay = document.getElementById('cert-name-display')
    const dateDisplay = document.getElementById('cert-date-display')
    const downloadBtn = document.getElementById('download-btn')

    // Default to today
    datumInput.value = new Date().toISOString().split('T')[0]
    updateDate()

    naamInput.addEventListener('input', () => {
      nameDisplay.textContent = naamInput.value.trim() || '—'
    })

    datumInput.addEventListener('change', updateDate)

    function updateDate() {
      const d = new Date(datumInput.value + 'T12:00:00')
      dateDisplay.textContent = d.toLocaleDateString('en-GB', {
        day: 'numeric', month: 'long', year: 'numeric'
      })
    }

    downloadBtn.addEventListener('click', () => {
      const naam = naamInput.value.trim() || 'Certificate'
      const el   = document.getElementById('certificaat')

      downloadBtn.textContent = 'Generating…'
      downloadBtn.disabled = true

      const opt = {
        margin:   0,
        filename: `Certificate_${naam.replace(/\s+/g, '_')}.pdf`,
        image:    { type: 'png' },
        html2canvas: {
          scale:       4,
          useCORS:     true,
          logging:     false,
          letterRendering: true,
        },
        jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' }
      }

      html2pdf().set(opt).from(el).save().then(() => {
        downloadBtn.textContent = '⬇ Download PDF'
        downloadBtn.disabled = false
      })
    })
  </script>
</body>
</html>
